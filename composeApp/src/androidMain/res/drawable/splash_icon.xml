<?xml version="1.0" encoding="utf-8"?>
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">
    
    <!-- Simple 3D cube icon for AR app -->
    <!-- White color to contrast with purple background -->
    <group
        android:translateX="54"
        android:translateY="54">
        
        <!-- Cube front face -->
        <path
            android:fillColor="#FFFFFF"
            android:pathData="M-12,-12 L12,-12 L12,12 L-12,12 Z" />
        
        <!-- Cube top face (lighter) -->
        <path
            android:fillColor="#E0E0E0"
            android:pathData="M-12,-12 L12,-12 L18,-18 L-6,-18 Z" />
        
        <!-- Cube right face (darker) -->
        <path
            android:fillColor="#BDBDBD"
            android:pathData="M12,-12 L12,12 L18,6 L18,-18 Z" />
    </group>
</vector>
